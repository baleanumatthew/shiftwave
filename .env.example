# Frontend env used by Vite locally and by Vercel in production.
# Leave blank during local development to use the default bridge at http://127.0.0.1:5185.
VITE_YOUTUBE_BRIDGE_BASE_URL=

# Optional bridge env for `npm run youtube-bridge`.
# Set this when the bridge is reachable from another machine or from your Vercel frontend.
YOUTUBE_BRIDGE_PUBLIC_URL=

# Optional bridge overrides.
# YOUTUBE_BRIDGE_HOST=127.0.0.1
# YOUTUBE_BRIDGE_PORT=5185
# YTDLP_BIN=yt-dlp
# FFMPEG_LOCATION=
